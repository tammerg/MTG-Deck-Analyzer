# MTG Deck Maker - Environment Variables

# Anthropic API key for LLM-powered deck advice (optional)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API key for LLM-powered deck advice (optional)
OPENAI_API_KEY=your_openai_api_key_here

# TCGAPIs key for real-time pricing (optional)
TCGAPIS_API_KEY=your_tcgapis_key_here

# JustTCG key for fallback pricing (optional)
JUSTTCG_API_KEY=your_justtcg_key_here

# Data directory (defaults to ./data)
MTG_DATA_DIR=./data

# Offline mode (set to true to skip external API calls)
MTG_OFFLINE_MODE=false

# Cache TTL in hours (default 24)
MTG_CACHE_TTL_HOURS=24
